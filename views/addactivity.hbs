<section class="page-header">
  <p class="eyebrow">Today is another chance</p>
  <h1>Log Today’s Movement</h1>
  <p>No pressure. No perfection. Just show up and record the work.</p>
</section>

<form class="form-card" action="/addactivity" method="POST">
  <label for="type">What did you do today?</label>
  <select name="type" id="type" required>
    <option value="Walking">Walking</option>
    <option value="Running">Running</option>
    <option value="Yoga">Yoga</option>
    <option value="Stretching">Stretching</option>
    <option value="Cycling">Cycling</option>
    <option value="Strength Training">Strength Training</option>
  </select>

  <label for="duration">How many minutes did you move?</label>
  <input type="number" name="duration" id="duration" min="1" required>

  <label for="intensity">How hard did you go?</label>
  <select name="intensity" id="intensity">
    <option value="Low">Low — I moved with ease</option>
    <option value="Moderate">Moderate — I challenged myself</option>
    <option value="High">High — I pushed today</option>
  </select>

  <label for="mood">How do you feel now?</label>
  <select name="mood" id="mood">
    <option value="Energized">Energized</option>
    <option value="Calm">Calm</option>
    <option value="Motivated">Motivated</option>
    <option value="Tired but proud">Tired but proud</option>
  </select>

  <label for="date">Date</label>
  <input type="date" name="date" id="date" required>

  <label for="notes">Champion note</label>
  <textarea name="notes" id="notes" rows="4" placeholder="Example: I did not feel like moving, but I showed up anyway."></textarea>

  <button type="submit">Keep the Streak Going</button>
</form>