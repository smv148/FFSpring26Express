<section class="page-header">
  <p class="eyebrow">Your receipts</p>
  <h1>Your Progress</h1>
  <p>Every entry is proof that you showed up. Keep stacking the days.</p>
</section>

<section class="card">
  {{#if activities.length}}
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Movement</th>
          <th>Time</th>
          <th>Effort</th>
          <th>Feeling</th>
          <th>Champion Note</th>
        </tr>
      </thead>
      <tbody>
        {{#each activities}}
          <tr>
            <td>{{this.date}}</td>
            <td>{{this.type}}</td>
            <td>{{this.duration}} min</td>
            <td>{{this.intensity}}</td>
            <td>{{this.mood}}</td>
            <td>{{this.notes}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No progress logged yet. One day is all it takes to start. Let’s go.</p>
  {{/if}}
</section>